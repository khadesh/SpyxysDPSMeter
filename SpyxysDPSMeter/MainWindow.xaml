<Window x:Class="SpyxysDPSMeter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Spyxy's DPS Meter"
        Width="520"
        Height="360"
        MinWidth="390"
        MinHeight="220"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        Topmost="True"
        ShowInTaskbar="True"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        Closed="Window_Closed"
        Icon="/Assets/icon-spyxy-dps.png">

    <Grid Margin="6">
        <Border Background="#E8181B20"
                BorderBrush="#AA57606A"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="26"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#EE252A31"
                        CornerRadius="8,8,0,0"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="38"/>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="TitleText"
                                   Grid.Column="0"
                                   Margin="12,0,6,0"
                                   VerticalAlignment="Center"
                                   Foreground="#FFF3F5F7"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   Text="Spyxy's DPS Meter"/>

                        <Grid Grid.Column="1">
                            <Button x:Name="InstantMessengerButton"
                                    Content="💬"
                                    Click="InstantMessengerButton_Click"
                                    Background="Transparent"
                                    Foreground="#FFD7DCE1"
                                    BorderThickness="0"
                                    FontFamily="Segoe UI Emoji"
                                    FontSize="15"
                                    Cursor="Hand"
                                    ToolTip="Open Instant Messenger"/>

                            <Border x:Name="InstantMessengerUnreadBadge"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,2,1,0"
                                    MinWidth="16"
                                    Height="16"
                                    Padding="3,0"
                                    CornerRadius="8"
                                    Background="#FF2A89D6"
                                    Visibility="Collapsed"
                                    IsHitTestVisible="False">
                                <TextBlock x:Name="InstantMessengerUnreadText"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Foreground="White"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           Text="0"/>
                            </Border>
                        </Grid>

                        <Button x:Name="SettingsButton"
                                Grid.Column="2"
                                Content="⚙"
                                Click="SettingsButton_Click"
                                Background="Transparent"
                                Foreground="#FFD7DCE1"
                                BorderThickness="0"
                                FontFamily="Segoe UI Symbol"
                                FontSize="15"
                                Cursor="Hand"
                                ToolTip="Display settings">
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem x:Name="PlayerNameMenuItem"
                                              Header="Player Name"
                                              Tag="PlayerName"
                                              IsCheckable="True"
                                              IsChecked="True"
                                              StaysOpenOnClick="True"
                                              Click="DisplaySettingMenuItem_Click"/>
                                    <MenuItem x:Name="ServerNameMenuItem"
                                              Header="Server Name"
                                              Tag="ServerName"
                                              IsCheckable="True"
                                              IsChecked="True"
                                              StaysOpenOnClick="True"
                                              Click="DisplaySettingMenuItem_Click"/>
                                    <MenuItem Header="Number Alignment">
                                        <MenuItem x:Name="NumberAlignmentLeftMenuItem"
                                                  Header="Left"
                                                  Tag="Left"
                                                  IsCheckable="True"
                                                  IsChecked="True"
                                                  StaysOpenOnClick="True"
                                                  Click="NumericAlignmentMenuItem_Click"/>
                                        <MenuItem x:Name="NumberAlignmentRightMenuItem"
                                                  Header="Right"
                                                  Tag="Right"
                                                  IsCheckable="True"
                                                  StaysOpenOnClick="True"
                                                  Click="NumericAlignmentMenuItem_Click"/>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem x:Name="ExperiencePerHourMenuItem"
                                              Header="XP/h"
                                              Tag="ExperiencePerHour"
                                              IsCheckable="True"
                                              IsChecked="True"
                                              StaysOpenOnClick="True"
                                              Click="DisplaySettingMenuItem_Click"/>
                                    <MenuItem x:Name="LastTenExperienceMenuItem"
                                              Header="Last 10 XP/h"
                                              Tag="LastTenExperience"
                                              IsCheckable="True"
                                              IsChecked="True"
                                              StaysOpenOnClick="True"
                                              Click="DisplaySettingMenuItem_Click"/>
                                    <MenuItem x:Name="PlatinumPerHourMenuItem"
                                              Header="Platinum/h"
                                              Tag="PlatinumPerHour"
                                              IsCheckable="True"
                                              IsChecked="True"
                                              StaysOpenOnClick="True"
                                              Click="DisplaySettingMenuItem_Click"/>
                                    <MenuItem Header="Platinum Mode">
                                        <MenuItem x:Name="PlatinumModeNormalMenuItem"
                                                  Header="Normal"
                                                  Tag="Normal"
                                                  IsCheckable="True"
                                                  StaysOpenOnClick="True"
                                                  Click="PlatinumModeMenuItem_Click"/>
                                        <MenuItem x:Name="PlatinumModeThrottledMenuItem"
                                                  Header="3m Throttled"
                                                  Tag="Throttled"
                                                  IsCheckable="True"
                                                  IsChecked="True"
                                                  StaysOpenOnClick="True"
                                                  Click="PlatinumModeMenuItem_Click"/>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Header="Data Filtering">
                                        <MenuItem x:Name="DataFilterAllDataMenuItem"
                                                  Header="All data"
                                                  Tag="AllData"
                                                  ToolTip="Show all parsed players, pets, enemies, and other entities. Intended for private instances."
                                                  IsCheckable="True"
                                                  IsChecked="True"
                                                  StaysOpenOnClick="True"
                                                  Click="DataFilteringMenuItem_Click"/>
                                        <MenuItem x:Name="DataFilterRemoveUnknownsMenuItem"
                                                  Header="Remove unknowns"
                                                  Tag="RemoveUnknowns"
                                                  ToolTip="Hide unclassified public players and pets while retaining known group members, your pet, and known enemies."
                                                  IsCheckable="True"
                                                  StaysOpenOnClick="True"
                                                  Click="DataFilteringMenuItem_Click"/>
                                        <MenuItem x:Name="DataFilterOnlyKnownsMenuItem"
                                                  Header="Only knowns"
                                                  Tag="OnlyKnowns"
                                                  ToolTip="Calculate only combat involving you, your pet, group members, and enemies directly engaged by them during the current encounter."
                                                  IsCheckable="True"
                                                  StaysOpenOnClick="True"
                                                  Click="DataFilteringMenuItem_Click"/>
                                    </MenuItem>
                                    <MenuItem x:Name="AlwaysShowGroupMembersMenuItem"
                                              Header="Always Show Group Members"
                                              Tag="AlwaysShowGroupMembers"
                                              IsCheckable="True"
                                              IsChecked="True"
                                              StaysOpenOnClick="True"
                                              Click="DisplaySettingMenuItem_Click"/>
                                    <MenuItem x:Name="MainAssistIndicatorsMenuItem"
                                              Header="Main Assist Indicators"
                                              Tag="MainAssistIndicators"
                                              IsCheckable="True"
                                              IsChecked="True"
                                              StaysOpenOnClick="True"
                                              Click="DisplaySettingMenuItem_Click"/>
                                    <MenuItem x:Name="SpellCastingSubtextMenuItem"
                                              Header="Spell Casting Subtext"
                                              Tag="SpellCastingSubtext"
                                              IsCheckable="True"
                                              IsChecked="True"
                                              StaysOpenOnClick="True"
                                              Click="DisplaySettingMenuItem_Click"/>
                                    <MenuItem x:Name="InstantMessengerMenuItem"
                                              Header="Instant Messenger"
                                              IsCheckable="True"
                                              IsChecked="True"
                                              StaysOpenOnClick="True"
                                              Click="InstantMessengerSettingMenuItem_Click"/>
                                    <MenuItem Header="Refresh Rate">
                                        <MenuItem x:Name="RefreshRate02MenuItem"
                                                  Header="0.2s"
                                                  Tag="0.2"
                                                  IsCheckable="True"
                                                  StaysOpenOnClick="True"
                                                  Click="RefreshRateMenuItem_Click"/>
                                        <MenuItem x:Name="RefreshRate05MenuItem"
                                                  Header="0.5s"
                                                  Tag="0.5"
                                                  IsCheckable="True"
                                                  StaysOpenOnClick="True"
                                                  Click="RefreshRateMenuItem_Click"/>
                                        <MenuItem x:Name="RefreshRate10MenuItem"
                                                  Header="1.0s (Default)"
                                                  Tag="1.0"
                                                  IsCheckable="True"
                                                  IsChecked="True"
                                                  StaysOpenOnClick="True"
                                                  Click="RefreshRateMenuItem_Click"/>
                                        <MenuItem x:Name="RefreshRate20MenuItem"
                                                  Header="2.0s"
                                                  Tag="2.0"
                                                  IsCheckable="True"
                                                  StaysOpenOnClick="True"
                                                  Click="RefreshRateMenuItem_Click"/>
                                        <MenuItem x:Name="RefreshRate30MenuItem"
                                                  Header="3.0s"
                                                  Tag="3.0"
                                                  IsCheckable="True"
                                                  StaysOpenOnClick="True"
                                                  Click="RefreshRateMenuItem_Click"/>
                                        <MenuItem x:Name="RefreshRate50MenuItem"
                                                  Header="5.0s"
                                                  Tag="5.0"
                                                  IsCheckable="True"
                                                  StaysOpenOnClick="True"
                                                  Click="RefreshRateMenuItem_Click"/>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem x:Name="LogDirectoryMenuItem"
                                              Header="Log Directory">
                                        <MenuItem x:Name="CurrentLogDirectoryMenuItem"
                                                  Header="Current: Logs"
                                                  IsEnabled="False"
                                                  ToolTipService.ShowOnDisabled="True"/>
                                        <Separator/>
                                        <MenuItem Header="Change Log Directory..."
                                                  Click="ChangeLogDirectoryMenuItem_Click"/>
                                        <MenuItem x:Name="RevertLogDirectoryMenuItem"
                                                  Header="Revert to Default"
                                                  Click="RevertLogDirectoryMenuItem_Click"/>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem x:Name="TagGroupMemberMenuItem"
                                              Header="Tag Group Member"/>
                                    <MenuItem x:Name="RemoveGroupMemberMenuItem"
                                              Header="Remove Manual Group Member"/>
                                    <Separator/>
                                    <MenuItem Header="Help">
                                        <MenuItem Header="Feature Guide..."
                                                  Click="FeatureGuideMenuItem_Click"/>
                                        <MenuItem Header="Open GitHub Project"
                                                  Click="OpenProjectPageMenuItem_Click"/>
                                    </MenuItem>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>

                        <Button Grid.Column="3"
                                Content="↻"
                                Click="ResetButton_Click"
                                Background="Transparent"
                                Foreground="#FFD7DCE1"
                                BorderThickness="0"
                                FontFamily="Segoe UI Symbol"
                                FontSize="17"
                                Cursor="Hand"
                                ToolTip="Reset DPS, XP and platinum tracking"/>

                        <Button Grid.Column="4"
                                Content="×"
                                Click="CloseButton_Click"
                                Background="Transparent"
                                Foreground="#FFFF9B9B"
                                BorderThickness="0"
                                FontSize="18"
                                Cursor="Hand"
                                ToolTip="Hide to system tray"/>
                    </Grid>
                </Border>

                <DataGrid x:Name="DpsGrid"
                          Grid.Row="1"
                          Margin="6,6,6,2"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="False"
                          CanUserResizeRows="False"
                          CanUserSortColumns="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          RowHeaderWidth="0"
                          RowHeight="44"
                          ColumnHeaderHeight="28"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          Background="Transparent"
                          BorderThickness="0"
                          Foreground="#FFF5F7F9"
                          HorizontalGridLinesBrush="Transparent"
                          VerticalGridLinesBrush="Transparent"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          EnableRowVirtualization="True"
                          MouseRightButtonUp="DpsGrid_MouseRightButtonUp">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#FF20252B"/>
                            <Setter Property="Foreground" Value="#FFC8CDD3"/>
                            <Setter Property="BorderBrush" Value="#FF343A42"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="8,0"/>
                        </Style>

                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="8,0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#334B5563"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>

                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="{Binding RowBrush}"/>
                            <Setter Property="Foreground" Value="{Binding TextBrush}"/>
                            <Setter Property="BorderBrush" Value="#223A414A"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.88"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Name" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Margin="0,0,5,0"
                                                   VerticalAlignment="Center"
                                                   FontFamily="Segoe UI Symbol"
                                                   FontSize="15"
                                                   Text="⚔">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMainAssist}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           TextTrimming="CharacterEllipsis">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsMainAssist}" Value="True">
                                                                    <Setter Property="TextDecorations" Value="Underline"/>
                                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <ItemsControl ItemsSource="{Binding Indicators}"
                                                              Margin="3,0,0,0"
                                                              VerticalAlignment="Center">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Glyph}"
                                                                       Foreground="{Binding Foreground}"
                                                                       ToolTip="{Binding ToolTip}"
                                                                       Margin="2,0,0,0"
                                                                       FontFamily="Segoe UI Symbol"
                                                                       FontSize="13"
                                                                       FontWeight="Bold"
                                                                       VerticalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Opacity" Value="{Binding Opacity}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsFlashing}"
                                                                                         Value="True">
                                                                                <DataTrigger.EnterActions>
                                                                                    <BeginStoryboard>
                                                                                        <Storyboard RepeatBehavior="Forever"
                                                                                                    AutoReverse="True">
                                                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                                             From="1"
                                                                                                             To="0.25"
                                                                                                             Duration="0:0:0.35"/>
                                                                                        </Storyboard>
                                                                                    </BeginStoryboard>
                                                                                </DataTrigger.EnterActions>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <TextBlock Text="Healing"
                                                           Margin="6,0,0,0"
                                                           Foreground="#FF59FF8A"
                                                           FontSize="11"
                                                           FontWeight="Bold"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Effect>
                                                        <DropShadowEffect Color="#FF4CFF80"
                                                                          BlurRadius="8"
                                                                          ShadowDepth="0"
                                                                          Opacity="0.9"/>
                                                    </TextBlock.Effect>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Setter Property="Opacity" Value="1"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ShowHealingAnimation}"
                                                                             Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <DataTrigger.EnterActions>
                                                                        <BeginStoryboard>
                                                                            <Storyboard RepeatBehavior="Forever"
                                                                                        AutoReverse="True">
                                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                                 From="1"
                                                                                                 To="0.18"
                                                                                                 Duration="0:0:0.42"/>
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </DataTrigger.EnterActions>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>

                                            <TextBlock Text="{Binding MainAssistTargetSubtext}"
                                                       Foreground="#FF62F58C"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasMainAssistTarget}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <TextBlock Text="{Binding TargetSubtext}"
                                                       Foreground="#FFFFB0B0"
                                                       FontSize="10"
                                                       TextTrimming="CharacterEllipsis">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasAssistMismatch}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <Grid TextBlock.FontSize="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.Style>
                                                    <Style TargetType="Grid">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasCastingSubtext}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Style>
                                                <TextBlock Grid.Column="0"
                                                           Text="casting "
                                                           Foreground="#FFC4C8CF"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding CastingSpellName}"
                                                           Foreground="{Binding CastingSpellBrush}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </StackPanel>

                                        <TextBlock Grid.Column="2"
                                                   Margin="6,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="#FFFF5E5E"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   Text="⚠">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasAssistMismatch}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard x:Name="MismatchFlashStoryboard">
                                                                    <Storyboard RepeatBehavior="Forever"
                                                                                AutoReverse="True">
                                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                         From="1"
                                                                                         To="0.15"
                                                                                         Duration="0:0:0.45"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                            <DataTrigger.ExitActions>
                                                                <StopStoryboard BeginStoryboardName="MismatchFlashStoryboard"/>
                                                            </DataTrigger.ExitActions>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Damage" Width="95">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DamageText}"
                                               TextAlignment="{Binding NumericTextAlignment}"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="DPS" Width="85">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DpsText}"
                                               TextAlignment="{Binding NumericTextAlignment}"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="2"
                        Background="#CC20242A"
                        CornerRadius="0,0,8,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="StatusText"
                                   Grid.Column="0"
                                   Margin="10,0,8,0"
                                   VerticalAlignment="Center"
                                   Foreground="#FF9EA6AF"
                                   FontSize="10"
                                   TextTrimming="CharacterEllipsis"
                                   Text="Looking for the newest EverQuest Legends log..."/>

                        <TextBlock Grid.Column="1"
                                   Margin="8,0,10,0"
                                   VerticalAlignment="Center"
                                   FontSize="10">
                            <Hyperlink NavigateUri="https://github.com/khadesh/SpyxysDPSMeter"
                                       RequestNavigate="ProjectLink_RequestNavigate"
                                       ToolTip="https://github.com/khadesh/SpyxysDPSMeter"
                                       Foreground="#FF72B7FF"
                                       TextDecorations="None">
                                Spyxy's DPS Meter
                            </Hyperlink>
                        </TextBlock>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
