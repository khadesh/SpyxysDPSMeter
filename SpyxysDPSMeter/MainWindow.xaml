<Window x:Class="SpyxysDPSMeter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Spyxy's DPS Meter"
        Width="520"
        Height="360"
        MinWidth="390"
        MinHeight="220"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        Topmost="True"
        ShowInTaskbar="True"
        Loaded="Window_Loaded"
        Closed="Window_Closed">

    <Grid Margin="6">
        <Border Background="#E8181B20"
                BorderBrush="#AA57606A"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="26"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#EE252A31"
                        CornerRadius="8,8,0,0"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="TitleText"
                                   Grid.Column="0"
                                   Margin="12,0,6,0"
                                   VerticalAlignment="Center"
                                   Foreground="#FFF3F5F7"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   Text="Spyxy's DPS Meter"/>

                        <Button x:Name="SettingsButton"
                                Grid.Column="1"
                                Content="⚙"
                                Click="SettingsButton_Click"
                                Background="Transparent"
                                Foreground="#FFD7DCE1"
                                BorderThickness="0"
                                FontFamily="Segoe UI Symbol"
                                FontSize="15"
                                Cursor="Hand"
                                ToolTip="Display settings">
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem x:Name="PlayerNameMenuItem"
                                              Header="Player Name"
                                              Tag="PlayerName"
                                              IsCheckable="True"
                                              IsChecked="True"
                                              StaysOpenOnClick="True"
                                              Click="DisplaySettingMenuItem_Click"/>
                                    <MenuItem x:Name="ServerNameMenuItem"
                                              Header="Server Name"
                                              Tag="ServerName"
                                              IsCheckable="True"
                                              IsChecked="True"
                                              StaysOpenOnClick="True"
                                              Click="DisplaySettingMenuItem_Click"/>
                                    <Separator/>
                                    <MenuItem x:Name="ExperiencePerHourMenuItem"
                                              Header="XP/h"
                                              Tag="ExperiencePerHour"
                                              IsCheckable="True"
                                              IsChecked="True"
                                              StaysOpenOnClick="True"
                                              Click="DisplaySettingMenuItem_Click"/>
                                    <MenuItem x:Name="LastTenExperienceMenuItem"
                                              Header="Last 10 XP/h"
                                              Tag="LastTenExperience"
                                              IsCheckable="True"
                                              IsChecked="True"
                                              StaysOpenOnClick="True"
                                              Click="DisplaySettingMenuItem_Click"/>
                                    <MenuItem x:Name="PlatinumPerHourMenuItem"
                                              Header="Platinum/h"
                                              Tag="PlatinumPerHour"
                                              IsCheckable="True"
                                              IsChecked="True"
                                              StaysOpenOnClick="True"
                                              Click="DisplaySettingMenuItem_Click"/>
                                    <Separator/>
                                    <MenuItem x:Name="UnknownEntitiesMenuItem"
                                              Header="Unknown Entities"
                                              Tag="UnknownEntities"
                                              IsCheckable="True"
                                              IsChecked="True"
                                              StaysOpenOnClick="True"
                                              Click="DisplaySettingMenuItem_Click"/>
                                    <Separator/>
                                    <MenuItem x:Name="TagGroupMemberMenuItem"
                                              Header="Tag Group Member"/>
                                    <MenuItem x:Name="RemoveGroupMemberMenuItem"
                                              Header="Remove Manual Group Member"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>

                        <Button Grid.Column="2"
                                Content="↻"
                                Click="ResetButton_Click"
                                Background="Transparent"
                                Foreground="#FFD7DCE1"
                                BorderThickness="0"
                                FontFamily="Segoe UI Symbol"
                                FontSize="17"
                                Cursor="Hand"
                                ToolTip="Reset DPS, XP and platinum tracking"/>

                        <Button Grid.Column="3"
                                Content="—"
                                Click="MinimizeButton_Click"
                                Background="Transparent"
                                Foreground="#FFD7DCE1"
                                BorderThickness="0"
                                FontSize="16"
                                Cursor="Hand"
                                ToolTip="Minimize"/>

                        <Button Grid.Column="4"
                                Content="×"
                                Click="CloseButton_Click"
                                Background="Transparent"
                                Foreground="#FFFF9B9B"
                                BorderThickness="0"
                                FontSize="18"
                                Cursor="Hand"
                                ToolTip="Close"/>
                    </Grid>
                </Border>

                <DataGrid x:Name="DpsGrid"
                          Grid.Row="1"
                          Margin="6,6,6,2"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="False"
                          CanUserResizeRows="False"
                          CanUserSortColumns="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          RowHeaderWidth="0"
                          RowHeight="29"
                          ColumnHeaderHeight="28"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          Background="Transparent"
                          BorderThickness="0"
                          Foreground="#FFF5F7F9"
                          HorizontalGridLinesBrush="Transparent"
                          VerticalGridLinesBrush="Transparent"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          EnableRowVirtualization="True">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#FF20252B"/>
                            <Setter Property="Foreground" Value="#FFC8CDD3"/>
                            <Setter Property="BorderBrush" Value="#FF343A42"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="8,0"/>
                        </Style>

                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="8,0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#334B5563"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>

                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="{Binding RowBrush}"/>
                            <Setter Property="Foreground" Value="{Binding TextBrush}"/>
                            <Setter Property="BorderBrush" Value="#223A414A"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.88"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name"
                                            Binding="{Binding DisplayName}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Damage"
                                            Binding="{Binding DamageText}"
                                            Width="95">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="DPS"
                                            Binding="{Binding DpsText}"
                                            Width="85">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="2"
                        Background="#CC20242A"
                        CornerRadius="0,0,8,8">
                    <TextBlock x:Name="StatusText"
                               Margin="10,0"
                               VerticalAlignment="Center"
                               Foreground="#FF9EA6AF"
                               FontSize="10"
                               TextTrimming="CharacterEllipsis"
                               Text="Looking for the newest EverQuest Legends log..."/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
