<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net7.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>

    <!-- Icon embedded into the compiled EXE -->
    <ApplicationIcon>Assets\icon-spyxy-dps.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <!-- PNG used by the WPF window/taskbar -->
    <Resource Include="Assets\icon-spyxy-dps.png" />
  </ItemGroup>

</Project>