<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Single source of truth for the app version.
         Bumping this on master triggers the release workflow. -->
    <Version>1.0.4</Version>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <UseSystemDrawing>true</UseSystemDrawing>
    <ApplicationIcon>Assets\icon-spyxy-dps.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Assets\icon-spyxy-dps.png" />
    <Resource Include="Assets\icon-spyxy-dps.png" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.Drawing.Common" Version="10.0.10" />
  </ItemGroup>

</Project>
